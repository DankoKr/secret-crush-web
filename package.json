    "vue-router": "^4.5.0",
    "vue-select": "^4.0.0-beta.6"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.13.2",
    "@types/tailwindcss": "^3.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.4",
    "sass": "^1.85.1",
    "sass-loader": "^16.0.5",
    "vue-tsc": "^2.0.19"
  }
